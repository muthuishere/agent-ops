#!/usr/bin/env python3
"""worktree-doctor — which of your agent fleet's git worktrees hold work that
would be LOST if the worktree were removed right now?

When you run parallel coding agents in git worktrees, each worktree is a place
work can quietly die: an agent edits but never commits, or commits to a branch
that was never pushed — then a cleanup (or `git worktree remove`) takes the
directory and the work with it (anthropics/claude-code#46444: ~10 days of
uncommitted work deleted by worktree auto-cleanup). worktree-doctor makes the
risk visible *before* cleanup runs.

A worktree is AT RISK if it has:
  • uncommitted changes (never committed — unrecoverable once the dir is gone), or
  • commits that are on no remote (lost if the branch/worktree is deleted).

Usage:
  worktree-doctor            # report all worktrees for the current repo
  worktree-doctor --quiet    # only print the at-risk ones
  exit code: 0 = all safe, 1 = at least one at-risk worktree (handy in a pre-cleanup check)
"""
import os
import subprocess
import sys
import time

RED = "\033[31m"; GREEN = "\033[32m"; DIM = "\033[2m"; RST = "\033[0m"
if not sys.stdout.isatty():
    RED = GREEN = DIM = RST = ""


def git(args, cwd=None):
    return subprocess.run(["git", *args], cwd=cwd, capture_output=True, text=True)


def parse_worktrees():
    r = git(["worktree", "list", "--porcelain"])
    if r.returncode != 0:
        sys.stderr.write("worktree-doctor: not inside a git repository\n")
        sys.exit(2)
    trees, cur = [], {}
    for line in r.stdout.splitlines():
        if not line.strip():
            if cur:
                trees.append(cur); cur = {}
            continue
        key, _, val = line.partition(" ")
        if key == "worktree":
            cur = {"path": val}
        elif key == "HEAD":
            cur["head"] = val
        elif key == "branch":
            cur["branch"] = val.replace("refs/heads/", "")
        elif key == "detached":
            cur["branch"] = "(detached)"
        elif key in ("locked", "prunable"):
            cur[key] = True
    if cur:
        trees.append(cur)
    return trees


def assess(wt):
    """Fill in dirty / unpushed / age / risk for one worktree."""
    path = wt["path"]
    wt["exists"] = os.path.isdir(path)
    if not wt["exists"]:
        wt["risk"] = False
        return wt
    dirty = git(["status", "--porcelain"], cwd=path).stdout.strip()
    wt["dirty"] = bool(dirty)
    # commits reachable from HEAD but on no remote-tracking branch → lost if removed.
    rc = git(["rev-list", "--count", "HEAD", "--not", "--remotes"], cwd=path)
    wt["unpushed"] = int(rc.stdout.strip()) if rc.returncode == 0 and rc.stdout.strip().isdigit() else 0
    ts = git(["log", "-1", "--format=%ct", "HEAD"], cwd=path).stdout.strip()
    wt["age_days"] = int((time.time() - int(ts)) // 86400) if ts.isdigit() else None
    wt["risk"] = wt["dirty"] or wt["unpushed"] > 0
    return wt


def main():
    quiet = "--quiet" in sys.argv
    trees = [assess(w) for w in parse_worktrees()]
    at_risk = [w for w in trees if w.get("risk")]

    n, m = len(trees), len(at_risk)
    head = f"worktree-doctor — {n} worktree{'s' if n != 1 else ''}, "
    head += f"{RED if m else GREEN}{m} at risk{RST}"
    print(head + "\n")

    for w in trees:
        if quiet and not w.get("risk"):
            continue
        dot = f"{RED}●{RST}" if w.get("risk") else f"{GREEN}○{RST}"
        flags = []
        if not w.get("exists"):
            flags.append("missing dir (prunable)")
        if w.get("dirty"):
            flags.append(f"{RED}uncommitted changes{RST}")
        if w.get("unpushed", 0) > 0:
            flags.append(f"{RED}{w['unpushed']} commit(s) on no remote{RST}")
        if w.get("locked"):
            flags.append("locked")
        if w.get("age_days") is not None and w["age_days"] >= 7:
            flags.append(f"{DIM}stale {w['age_days']}d{RST}")
        tail = ("  " + " · ".join(flags)) if flags else f"  {GREEN}safe{RST}"
        print(f"  {dot} {w['path']}  {DIM}[{w.get('branch','?')}]{RST}{tail}")

    if m:
        print(f"\n{DIM}commit or push the flagged worktrees before any cleanup — "
              f"`git -C <path> stash` or a throwaway WIP commit is enough.{RST}")
    sys.exit(1 if m else 0)


if __name__ == "__main__":
    main()
