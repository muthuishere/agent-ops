#!/usr/bin/env python3
"""ignorelint — does your ignore config actually keep secrets out of git and the agent?

leaklint scans output for secret *values*; ignorelint checks the other side — the ignore
files that decide which *files* git commits and an AI agent is allowed to read. A `.env`
that no rule ignores is both committable and readable by the agent. A `!`-negation can
quietly re-expose a key you thought was excluded. A re-include under an already-ignored
directory is dead and does nothing. ignorelint reads `.gitignore` (and `.claudeignore` /
`.cursorignore` / `.aiexclude`) and the files actually on disk, and flags those gaps.

  ignorelint [dir]   # default: .

It NEVER prints file contents — only filenames and the rule at fault. Exit 0 = no
high-severity issues, 1 = at least one HIGH/CRITICAL finding.

Heuristic, not git itself: ignorelint implements the common gitignore shapes (basename,
anchored, `*`/`**`, dir-only, `!`-negation, last-match-wins). It is a high-signal lint,
not a byte-exact reimplementation of git's matcher.
"""
import fnmatch
import os
import re
import sys

RED = "\033[31m"; YEL = "\033[33m"; CYN = "\033[36m"; DIM = "\033[2m"; RST = "\033[0m"
if not sys.stdout.isatty():
    RED = YEL = CYN = DIM = RST = ""
SEV = {"CRITICAL": RED, "HIGH": RED, "WARN": YEL, "INFO": CYN}

AGENT_IGNORES = (".claudeignore", ".cursorignore", ".aiexclude", ".codeiumignore")
SKIP_DIRS = {".git", ".hg", ".svn"}

SECRET_GLOBS = [
    ".env", ".env.*", "*.env", "*.pem", "*.key", "id_rsa", "id_dsa", "id_ecdsa", "id_ed25519",
    "*.p12", "*.pfx", "*.pkcs12", "*.keystore", "*.jks", "*.ppk",
    "credentials.json", "credentials.yml", "credentials.yaml", "service-account*.json",
]
SAFE_ENV_SUFFIXES = (".example", ".sample", ".template", ".dist", ".tpl", ".defaults")


def is_secret_name(name):
    if name.endswith(".pub"):
        return False
    low = name.lower()
    if low.startswith(".env") and any(low.endswith(s) for s in SAFE_ENV_SUFFIXES):
        return False
    return any(fnmatch.fnmatch(name, g) for g in SECRET_GLOBS)


class Rule:
    __slots__ = ("body", "negated", "dir_only", "anchored", "raw")

    def __init__(self, line):
        self.raw = line
        s = line
        self.negated = s.startswith("!")
        if self.negated:
            s = s[1:]
        self.dir_only = s.endswith("/")
        s = s.rstrip("/")
        self.anchored = s.startswith("/") or ("/" in s)
        self.body = s.lstrip("/")


def parse_rules(text):
    """Returns [(Rule, raw_line), ...], skipping blanks and # comments."""
    rules = []
    for line in text.splitlines():
        if line.strip() == "" or line.lstrip().startswith("#"):
            continue
        # keep trailing whitespace: git treats it literally, so a pattern with a
        # stray trailing space genuinely won't match (and the secret stays exposed).
        rules.append((Rule(line), line))
    return rules


def _seg_match(pat, seg):
    return fnmatch.fnmatch(seg, pat)


def _anchored_match(pat, path):
    """Match an anchored (slash-bearing) gitignore pattern against a relative path."""
    rx, i, n = "^", 0, len(pat)
    while i < n:
        if pat[i:i+3] == "**/":
            rx += "(?:.*/)?"; i += 3
        elif pat[i:i+2] == "**":
            rx += ".*"; i += 2
        elif pat[i] == "*":
            rx += "[^/]*"; i += 1
        elif pat[i] == "?":
            rx += "[^/]"; i += 1
        else:
            rx += re.escape(pat[i]); i += 1
    rx += "(?:/.*)?$"   # the path itself, or anything beneath it
    return re.match(rx, path) is not None


def rule_matches(rule, path, is_dir):
    segs = path.split("/")
    if not rule.anchored:
        if rule.dir_only:
            cand = segs if is_dir else segs[:-1]
            return any(_seg_match(rule.body, s) for s in cand)
        if is_dir:
            return any(_seg_match(rule.body, s) for s in segs)
        return _seg_match(rule.body, segs[-1]) or any(_seg_match(rule.body, s) for s in segs[:-1])
    return _anchored_match(rule.body, path)


def is_ignored(path, rules, is_dir=False):
    """gitignore semantics: last matching rule wins."""
    result = False
    for rule, _raw in rules:
        if rule_matches(rule, path, is_dir):
            result = not rule.negated
    return result


def is_ignored_dir_positive(dirpath, rules, exclude):
    """Is dirpath ignored by a positive rule other than `exclude`?"""
    for rule, _raw in rules:
        if rule is exclude or rule.negated:
            continue
        if rule_matches(rule, dirpath, True):
            return True
    return False


def parent_dirs(path):
    segs = path.split("/")
    return ["/".join(segs[:i]) for i in range(1, len(segs))]


def audit(root):
    findings = []
    add = lambda s, t, d: findings.append((s, t, d))

    gi_path = os.path.join(root, ".gitignore")
    gi_text = open(gi_path).read() if os.path.exists(gi_path) else ""
    rules = parse_rules(gi_text)

    # 1. trailing-whitespace patterns (git treats them literally -> silently never match)
    for rule, raw in rules:
        if raw != raw.rstrip() and not raw.rstrip().endswith("\\"):
            add("WARN", f"ignore pattern '{raw.strip()}' has trailing whitespace",
                "git treats trailing spaces literally, so this pattern silently won't match. "
                "Remove the spaces (or escape a deliberate one with a backslash).")

    # 2. ignore-everything patterns
    for rule, raw in rules:
        if not rule.negated and rule.body in ("*", "**", "", "."):
            add("WARN", f"ignore pattern '{raw.strip()}' excludes the entire tree",
                "git (and an agent reading this) then sees nothing here unless re-included. "
                "Did you mean to scope it to a subdirectory?")

    # 3. negation that re-exposes a secret file
    for rule, raw in rules:
        if rule.negated and is_secret_name(os.path.basename(rule.body)):
            add("HIGH", f"negation '{raw.strip()}' re-includes a secret-looking file",
                "a '!' rule un-ignores this path — git will track it and the agent can read it. "
                "Don't re-include credential files.")

    # 4. dead re-include under an ignored directory
    for rule, raw in rules:
        if rule.negated and rule.anchored:
            for parent in parent_dirs(rule.body):
                if is_ignored_dir_positive(parent, rules, rule):
                    add("WARN", f"negation '{raw.strip()}' is dead — a parent directory is ignored",
                        "git cannot re-include a file once its parent directory is excluded. "
                        f"Re-include the directory first (e.g. '!{parent}/'), or don't ignore it.")
                    break

    # 5. secret files on disk that nothing ignores  (+ 6: git-ignored but agent-visible)
    secrets = []
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
        for fn in filenames:
            if is_secret_name(fn):
                rel = os.path.relpath(os.path.join(dirpath, fn), root).replace(os.sep, "/")
                secrets.append(rel)

    agent_rules = {}
    for ai in AGENT_IGNORES:
        ai_path = os.path.join(root, ai)
        if os.path.exists(ai_path):
            agent_rules[ai] = parse_rules(open(ai_path).read())

    for rel in sorted(secrets):
        if not is_ignored(rel, rules):
            where = ".gitignore" if rules else "no .gitignore"
            add("HIGH", f"secret file '{rel}' is not ignored",
                f"it is present on disk and no rule in {where} excludes it — it can be committed "
                "and is readable by any agent with repo access. Add it to .gitignore.")
        else:
            for ai, ai_rules in agent_rules.items():
                if not is_ignored(rel, ai_rules):
                    add("WARN", f"secret file '{rel}' is git-ignored but not in {ai}",
                        f"{ai} curates what the AI agent reads; this secret is excluded from git "
                        f"but still visible to the agent. Mirror it into {ai}.")
    return findings


def main():
    root = sys.argv[1] if len(sys.argv) > 1 else "."
    if not os.path.isdir(root):
        sys.stderr.write(f"ignorelint: not a directory: {root}\n"); sys.exit(2)

    findings = audit(root)
    # dedupe by title, keep highest severity occurrence
    order = {"CRITICAL": 0, "HIGH": 1, "WARN": 2, "INFO": 3}
    best = {}
    for sev, title, detail in findings:
        if title not in best or order[sev] < order[best[title][0]]:
            best[title] = (sev, detail)
    uniq = [(sev, t, d) for t, (sev, d) in best.items()]

    label = root if root == "." else os.path.relpath(root)
    print(f"ignorelint — {label}\n")
    if not uniq:
        print("  ✓ no ignore-config gaps found.")
        sys.exit(0)
    for sev, title, detail in sorted(uniq, key=lambda f: order[f[0]]):
        print(f"  {SEV[sev]}● {sev:<8}{RST} {title}")
        print(f"             {DIM}{detail}{RST}")
    high = sum(1 for s, _, _ in uniq if s in ("CRITICAL", "HIGH"))
    print()
    print(f"  {RED if high else YEL}{len(uniq)} finding(s)"
          + (f", {high} high-severity" if high else "") + f".{RST}")
    sys.exit(1 if high else 0)


if __name__ == "__main__":
    main()
